# MongoDB – ADD YOUR CONNECTION URL HERE
# Local: mongodb://localhost:27017/railway_reservation
# Atlas: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/railway_reservation?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/railway_reservation

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (optional - for booking confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Razorpay (optional - for payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
